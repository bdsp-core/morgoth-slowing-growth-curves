# Data — never commit PHI or large data
data/*
!data/.gitkeep
*.edf
*.bdf
*.set
*.fif
*.npz
*.parquet
*.mat

# Staged panel source tree (2.4 GB; upload to S3, never commit) — see scripts/128_stage_panels.py
panels/

# Local config with credentials/paths
config/config.yaml

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/

# Outputs
outputs/
*.log
# figures/ ARE committed (results deliverables) — small PNGs

# model weights: keep out of git (they live on S3: morgoth2/models/202605/morgoth/)
*.pth
checkpoints_s3/

# AWS credentials — never commit
*accessKeys*.csv
fleet/*accessKeys*.csv
*_accessKeys.csv
.aws/

# fleet operational scratch (transient)
fleet/.*

# original-abnormal staging CSVs (7464 files, backed up to S3 .../Growth_curves/original_abnormal_stages/)
data/derived/original_abnormal_stages/

# Raw report text / PHI-derived artifacts — NEVER commit (only derived labels are published)
results/report_labeler.html
results/gen_label_review.html
results/labeling_cases.csv
models/

# EEG review viewer (V3): pre-exported signal clips + rater responses — NEVER commit.
# The case_id -> bdsp_id key lives ONLY in the scratchpad (case_crosswalk.jsonl), never here.
viewer/data/

# fleet work manifests (per-patient ids; regenerable)
fleet/manifest_pilot.jsonl
fleet/manifest_full.jsonl
PREFLATSTRIP.parquet
band_test_features.parquet

# Copyrighted reference PDFs — not committed (see references/README.md)
references/*.pdf

# The authoritative age table MUST be versioned. `*.parquet` above would otherwise drop it,
# and every analysis would silently fall back to the manifest's INTEGER ages (partly wrong: 7
# negatives, errors up to 10 y). It is small (~1 MB), HIPAA-safe (>89 binned to 90) and is the
# single source of truth that scripts/34 + fleet_analysis_adapter.py + label_rederive_sap.py read.
!metadata/ages_v6.parquet

# rclone remote with live BDSP keys — SHIPPED IN THE BUNDLE (private S3), NEVER COMMITTED
fleet/rclone_s3.conf
